{
  "name": "react-perf-hooks",
  "version": "1.7.0",
  "description": "React hooks for performance monitoring, profiling, and Core Web Vitals measurement",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "packageManager": "pnpm@10.33.3",
  "scripts": {
    "docusaurus": "docusaurus",
    "build": "tsup",
    "docs:dev": "docusaurus start",
    "docs:build": "docusaurus build --out-dir docs-build",
    "docs:serve": "docusaurus serve --dir docs-build",
    "docs:clear": "docusaurus clear",
    "docs:type-check": "tsc -p tsconfig.docs.json",
    "build:watch": "tsup --watch",
    "build:check": "pnpm type-check && pnpm build",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/index.ts src/hooks src/test-setup.ts",
    "lint:fix": "eslint src/index.ts src/hooks src/test-setup.ts --fix",
    "format": "prettier --write \"{src,docs,examples}/**/*.{ts,tsx,js,jsx,mjs,cjs,mts,cts,md,mdx}\" \"*.{ts,js,mjs,json,md}\"",
    "format:check": "prettier --check \"{src,docs,examples}/**/*.{ts,tsx,js,jsx,mjs,cjs,mts,cts,md,mdx}\" \"*.{ts,js,mjs,json,md}\"",
    "ci": "pnpm type-check && pnpm lint && pnpm format:check && pnpm test:run && pnpm build",
    "prepublishOnly": "pnpm run ci",
    "release:patch": "pnpm version patch && pnpm publish --access public",
    "release:minor": "pnpm version minor && pnpm publish --access public",
    "release:major": "pnpm version major && pnpm publish --access public"
  },
  "peerDependencies": {
    "react": ">=16.8.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": false
    }
  },
  "optionalDependencies": {
    "web-vitals": "^5.2.0"
  },
  "devDependencies": {
    "@docusaurus/core": "3.10.0",
    "@docusaurus/faster": "3.10.0",
    "@docusaurus/module-type-aliases": "3.10.0",
    "@docusaurus/preset-classic": "3.10.0",
    "@docusaurus/tsconfig": "3.10.0",
    "@docusaurus/types": "3.10.0",
    "@eslint/js": "^9.39.0",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@mdx-js/react": "^3.0.0",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.0",
    "@vitest/coverage-v8": "^4.1.0",
    "clsx": "^2.0.0",
    "eslint": "^9.39.0",
    "eslint-plugin-react-hooks": "7.0.1",
    "jsdom": "^29.0.0",
    "prettier": "^3.3.3",
    "prism-react-renderer": "^2.3.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tsup": "^8.0.2",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.3.0",
    "vitest": "^4.1.0",
    "web-vitals": "^5.2.0"
  },
  "keywords": [
    "react",
    "hooks",
    "performance",
    "web-vitals",
    "profiling",
    "optimization",
    "render-tracking",
    "performance-api",
    "core-web-vitals",
    "typescript"
  ],
  "author": {
    "name": "Valentyn Yefimov"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/valyefimov/react-perf-hooks.git"
  },
  "bugs": {
    "url": "https://github.com/valyefimov/react-perf-hooks/issues"
  },
  "homepage": "https://github.com/valyefimov/react-perf-hooks#readme",
  "engines": {
    "node": ">=20"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 3 chrome version",
      "last 3 firefox version",
      "last 5 safari version"
    ]
  }
}
