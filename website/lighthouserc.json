{
  "ci": {
    "collect": {
      "numberOfRuns": 1,
      "startServerCommand": "npm run serve -- --host 0.0.0.0 --port 3000",
      "startServerReadyTimeout": 30000,
      "settings": {
        "preset": "desktop",
        "throttlingMethod": "provided"
      },
      "url": [
        "http://127.0.0.1:3000/react-perf-hooks/",
        "http://127.0.0.1:3000/react-perf-hooks/docs/getting-started",
        "http://127.0.0.1:3000/react-perf-hooks/docs/hooks/use-render-tracker"
      ]
    },
    "assert": {
      "assertions": {
        "categories:performance": [
          "error",
          {
            "minScore": 0.9
          }
        ],
        "categories:accessibility": [
          "error",
          {
            "minScore": 0.9
          }
        ]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
