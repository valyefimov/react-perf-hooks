{
  "compilerOptions": {
    "allowJs": true,
    "esModuleInterop": true,
    "jsx": "preserve",
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "moduleResolution": "bundler",
    "module": "esnext",
    "noEmit": true,
    "paths": {
      "@site/*": ["./*"]
    },
    "skipLibCheck": true,
    "strict": true
  },
  "include": [
    "docusaurus.config.ts",
    "sidebars.ts",
    "src/components/**/*",
    "src/pages/**/*",
    "docs/**/*"
  ],
  "exclude": ["node_modules", ".docusaurus", "build", "dist"]
}
